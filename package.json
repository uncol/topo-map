{
  "name": "topo-map",
  "version": "1.0.0",
  "description": "Interactive JointJS topology map module",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "tsc -p tsconfig.build.json && node ./scripts/prepare-demo.mjs",
    "build:watch": "node ./scripts/watch-with-autoreload.mjs",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@gufo-labs/font": "^0.0.9",
    "@joint/core": "4.2.4",
    "rbush": "4.0.1"
  },
  "devDependencies": {
    "typescript": "5.9.3"
  }
}
